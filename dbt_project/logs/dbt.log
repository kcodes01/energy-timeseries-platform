        create table `energy_marts_marts`.`mart_capture_prices`
        
  
        
  engine = MergeTree()
        
      order by (tuple())
        
        
        SETTINGS  replicated_deduplication_window=0

            empty
          as (
            with base as (
    select
        p.date                                      as date,
        p.value                                     as price_eur_mwh,
        r.onshore_wind_mwh                          as onshore_wind_mwh,
        r.solar_mwh                                 as solar_mwh,
        r.offshore_wind_mwh                         as offshore_wind_mwh,
        r.total_renewable_mwh                       as total_renewable_mwh,
        p.value * r.total_renewable_mwh             as weighted_price
    from `energy_marts_staging`.`stg_energy_timeseries` p
    left join `energy_marts_intermediate`.`int_renewable_generation` r
        on p.timestamp = r.timestamp
    where p.category = 'price'
    and p.filter_id = 4169
)

select
    date,
    round(sum(weighted_price) / nullIf(sum(total_renewable_mwh), 0), 2)    as capture_price_eur_mwh,
    round(avg(price_eur_mwh), 2)                                            as avg_market_price_eur_mwh,
    round(sum(total_renewable_mwh), 0)                                      as total_renewable_mwh,
    round(sum(solar_mwh), 0)                                                as solar_mwh,
    round(sum(onshore_wind_mwh), 0)                                         as onshore_wind_mwh,
    round(sum(offshore_wind_mwh), 0)                                        as offshore_wind_mwh
from base
group by date
order by date desc
          )
        ...
