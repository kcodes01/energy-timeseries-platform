        SETTINGS  replicated_deduplication_window=0

            empty
          as (
            with prices as (
    select
        timestamp,
        date,
        value as price_eur_mwh
    from `energy_marts_staging`.`stg_energy_timeseries`
    where category = 'price'
    and filter_id = 4169
),

renewables as (
    select
        timestamp,
        date,
        onshore_wind_mwh,
        solar_mwh,
        offshore_wind_mwh,
        total_renewable_mwh
    from `energy_marts_intermediate`.`int_renewable_generation`
),

joined as (
    select
        p.date                      as date,
        p.price_eur_mwh             as price_eur_mwh,
        r.onshore_wind_mwh          as onshore_wind_mwh,
        r.solar_mwh                 as solar_mwh,
        r.offshore_wind_mwh         as offshore_wind_mwh,
        r.total_renewable_mwh       as total_renewable_mwh,
        p.price_eur_mwh * r.total_renewable_mwh as weighted_price
    from prices p
    left join renewables r on p.timestamp = r.timestamp
)

select
    date,
    round(
        sum(weighted_price) / nullIf(sum(total_renewable_mwh), 0)
    , 2)                                as capture_price_eur_mwh,
    round(avg(price_eur_mwh), 2)        as avg_market_price_eur_mwh,
    round(sum(total_renewable_mwh), 0)  as total_renewable_mwh,
    round(sum(solar_mwh), 0)            as solar_mwh,
    round(sum(onshore_wind_mwh), 0)     as onshore_wind_mwh,
    round(sum(offshore_wind_mwh), 0)    as offshore_wind_mwh
from joined
group by date
order by date desc
          )
