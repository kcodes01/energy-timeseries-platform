,'int_residual_load','OK','success','model',0.015421628952026367,'2026-06-30T09:13:43.646861Z','2026-06-30T09:13:43.659131Z','2026-06-30T09:13:43.644043Z','2026-06-30T09:13:43.646698Z',NULL,False,'with consumption as (\n    select\n        timestamp,\n        date,\n        hour_of_day,\n        sumIf(value, filter_id = 410)   as total_load_mwh,\n        sumIf(value, filter_id = 4359)  as residual_load_mwh\n    from `energy_marts_staging`.`stg_energy_timeseries`\n    where category = \'consumption\'\n    group by timestamp, date, hour_of_day\n)\n\nselect\n    timestamp,\n    date,\n    hour_of_day,\n    total_load_mwh,\n    residual_load_mwh,\n    -- renewable coverage\n    total_load_mwh - residual_load_mwh  as renewable_coverage_mwh,\n    round(\n        (total_load_mwh - residual_load_mwh) / nullIf(total_load_mwh, 0) * 100, 2\n    )                                    as renewable_pct\nfrom consumption\norder by timestamp',NULL,'6b4dc967-913e-4779-8fcf-2ec2c2883a1b','Thread-1 (worker)','view','{"_message": "OK", "query_id": "6b4dc967-913e-4779-8fcf-2ec2c2883a1b"}'),('d715940b-b1ef-44cb-b79d-6f386c07ec95.model.dbt_project.mart_daily_price_summary','model.dbt_project.mart_daily_price_summary','d715940b-b1ef-44cb-b79d-6f386c07ec95','2026-06-30 09:13:50',
