,'int_renewable_generation','OK','success','model',0.009933710098266602,'2026-06-30T09:18:55.773521Z','2026-06-30T09:18:55.781051Z','2026-06-30T09:18:55.771539Z','2026-06-30T09:18:55.773299Z',NULL,False,'with generation as (\n    select * from `energy_marts_staging`.`stg_energy_timeseries`\n    where category = \'generation\'\n    and filter_id in (4067, 4068, 1225)\n)\n\nselect\n    timestamp,\n    date,\n    hour_of_day,\n    if(filter_id = 4067, value, 0)   as onshore_wind_mwh,\n    if(filter_id = 4068, value, 0)   as solar_mwh,\n    if(filter_id = 1225, value, 0)   as offshore_wind_mwh,\n    value                             as total_renewable_mwh\nfrom generation',NULL,'4c3a8791-3f47-4f13-a959-45106a64e87f','Thread-1 (worker)','view','{"_message": "OK", "query_id": "4c3a8791-3f47-4f13-a959-45106a64e87f"}'),('3de50297-474d-4e9d-b00c-aa02072160d4.model.dbt_project.int_residual_load','model.dbt_project.int_residual_load','3de50297-474d-4e9d-b00c-aa02072160d4','2026-06-30 09:18:58',
    current_timestamp::timestamp
,'int_residual_load','OK','success','model',0.00983738899230957,'2026-06-30T09:18:55.784524Z','2026-06-30T09:18:55.792138Z','2026-06-30T09:18:55.782689Z','2026-06-30T09:18:55.784370Z',NULL,False,'with consumption as (\n    select\n        timestamp,\n        date,\n        hour_of_day,\n        sumIf(value, filter_id = 410)   as total_load_mwh,\n        sumIf(value, filter_id = 4359)  as residual_load_mwh\n    from `energy_marts_staging`.`stg_energy_timeseries`\n    where category = \'consumption\'\n    group by timestamp, date, hour_of_day\n)\n\nselect\n    timestamp,\n    date,\n    hour_of_day,\n    total_load_mwh,\n    residual_load_mwh,\n    -- renewable coverage\n    total_load_mwh - residual_load_mwh  as renewable_coverage_mwh,\n    round(\n        (total_load_mwh - residual_load_mwh) / nullIf(total_load_mwh, 0) * 100, 2\n    )                                    as renewable_pct\nfrom consumption\norder by timestamp',NULL,'2ff4e852-81a4-4fdd-b99c-0fdbcde9c031','Thread-1 (worker)','view','{"_message": "OK", "query_id": "2ff4e852-81a4-4fdd-b99c-0fdbcde9c031"}'),('3de50297-474d-4e9d-b00c-aa02072160d4.model.dbt_project.mart_daily_price_summary','model.dbt_project.mart_daily_price_summary','3de50297-474d-4e9d-b00c-aa02072160d4','2026-06-30 09:18:58',
