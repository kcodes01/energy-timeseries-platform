    current_timestamp::timestamp
,'int_residual_load','OK','success','model',0.009598731994628906,'2026-06-30T09:58:38.321971Z','2026-06-30T09:58:38.329433Z','2026-06-30T09:58:38.320176Z','2026-06-30T09:58:38.321791Z',NULL,False,'with consumption as (\n    select\n        timestamp,\n        date,\n        hour_of_day,\n        sumIf(value, filter_id = 410)   as total_load_mwh,\n        sumIf(value, filter_id = 4359)  as residual_load_mwh\n    from `energy_marts_staging`.`stg_energy_timeseries`\n    where category = \'consumption\'\n    group by timestamp, date, hour_of_day\n)\n\nselect\n    timestamp,\n    date,\n    hour_of_day,\n    total_load_mwh,\n    residual_load_mwh,\n    -- renewable coverage\n    total_load_mwh - residual_load_mwh  as renewable_coverage_mwh,\n    round(\n        (total_load_mwh - residual_load_mwh) / nullIf(total_load_mwh, 0) * 100, 2\n    )                                    as renewable_pct\nfrom consumption\norder by timestamp',NULL,'84c20181-67f6-4f26-b965-c2ef8e1441fe','Thread-1 (worker)','view','{"_message": "OK", "query_id": "84c20181-67f6-4f26-b965-c2ef8e1441fe"}'),('82b5a0e3-6747-4f51-b51f-0b72849ca504.model.dbt_project.mart_daily_price_summary','model.dbt_project.mart_daily_price_summary','82b5a0e3-6747-4f51-b51f-0b72849ca504','2026-06-30 09:58:41',
