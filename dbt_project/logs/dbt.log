    current_timestamp::timestamp
,'test_result_rows','OK','success','model',0.049045562744140625,'2026-06-30T09:13:45.699033Z','2026-06-30T09:13:45.743042Z','2026-06-30T09:13:45.694392Z','2026-06-30T09:13:45.698832Z',NULL,False,'\n\n-- depends_on: `energy_marts`.`elementary_test_results`\nselect * from (\n            select\n            \n                \n        cast(\'this_is_just_a_long_dummy_string\' as varchar(4096)) as elementary_test_results_id\n\n,\n                \n        cast(\'this_is_just_a_long_dummy_string\' as varchar(4096)) as result_row\n\n,\n                cast(\'2091-02-17\' as DateTime) as detected_at\n\n,\n                cast(\'2091-02-17\' as DateTime) as created_at\n\n\n        ) as empty_table\n        where 1 = 0',NULL,'595cdd5e-1629-4fd2-b7d5-811463a080b9','Thread-1 (worker)','incremental','{"_message": "OK", "query_id": "595cdd5e-1629-4fd2-b7d5-811463a080b9"}'),('d715940b-b1ef-44cb-b79d-6f386c07ec95.model.dbt_project.mart_capture_prices','model.dbt_project.mart_capture_prices','d715940b-b1ef-44cb-b79d-6f386c07ec95','2026-06-30 09:13:50',
    current_timestamp::timestamp
,'mart_capture_prices','OK','success','model',0.334944486618042,'2026-06-30T09:13:45.746637Z','2026-06-30T09:13:46.079152Z','2026-06-30T09:13:45.744622Z','2026-06-30T09:13:45.746441Z',NULL,False,'with base as (\n    select\n        p.date                                      as date,\n        p.value                                     as price_eur_mwh,\n        r.onshore_wind_mwh                          as onshore_wind_mwh,\n        r.solar_mwh                                 as solar_mwh,\n        r.offshore_wind_mwh                         as offshore_wind_mwh,\n        r.total_renewable_mwh                       as total_renewable_mwh,\n        p.value * r.total_renewable_mwh             as weighted_price\n    from `energy_marts_staging`.`stg_energy_timeseries` p\n    left join `energy_marts_intermediate`.`int_renewable_generation` r\n        on p.timestamp = r.timestamp\n    where p.category = \'price\'\n    and p.filter_id = 4169\n),\n\naggregated as (\n    select\n        date,\n        sum(weighted_price)         as sum_weighted_price,\n        sum(total_renewable_mwh)    as sum_renewable_mwh,\n        avg(price_eur_mwh)          as avg_price,\n        sum(solar_mwh)              as sum_solar,\n        sum(onshore_wind_mwh)       as sum_onshore,\n        sum(offshore_wind_mwh)      as sum_offshore\n    from base\n    group by date\n)\n\nselect\n    date,\n    round(sum_weighted_price / sum_renewable_mwh, 2)    as capture_price_eur_mwh,\n    round(avg_price, 2)                                  as avg_market_price_eur_mwh,\n    round(sum_renewable_mwh, 0)                         as total_renewable_mwh,\n    round(sum_solar, 0)                                 as solar_mwh,\n    round(sum_onshore, 0)                               as onshore_wind_mwh,\n    round(sum_offshore, 0)                              as offshore_wind_mwh\nfrom aggregated\norder by date desc',NULL,'4598616c-ad9f-4e71-80ac-2b5f27503bd3','Thread-1 (worker)','table','{"_message": "OK", "query_id": "4598616c-ad9f-4e71-80ac-2b5f27503bd3"}'),('d715940b-b1ef-44cb-b79d-6f386c07ec95.model.dbt_project.mart_flexibility_signals','model.dbt_project.mart_flexibility_signals','d715940b-b1ef-44cb-b79d-6f386c07ec95','2026-06-30 09:13:50',
    current_timestamp::timestamp
,'mart_flexibility_signals','OK','success','model',4.101895570755005,'2026-06-30T09:13:46.083537Z','2026-06-30T09:13:50.182416Z','2026-06-30T09:13:46.081142Z','2026-06-30T09:13:46.083362Z',NULL,False,'with prices as (\n    select\n        timestamp,\n        date,\n        hour_of_day,\n        value as price_eur_mwh\n    from `energy_marts_staging`.`stg_energy_timeseries`\n    where category = \'price\'\n    and filter_id = 4169\n),\n\nresidual as (\n    select * from `energy_marts_intermediate`.`int_residual_load`\n),\n\nrenewables as (\n    select * from `energy_marts_intermediate`.`int_renewable_generation`\n),\n\njoined as (\n    select\n        p.timestamp                 as timestamp,\n        p.date                      as date,\n        p.hour_of_day               as hour_of_day,\n        p.price_eur_mwh             as price_eur_mwh,\n        r.residual_load_mwh         as residual_load_mwh,\n        r.renewable_pct             as renewable_pct,\n        rn.total_renewable_mwh      as total_renewable_mwh,\n        multiIf(\n            p.price_eur_mwh < 50 and r.renewable_pct > 50, \'OPTIMAL\',\n            p.price_eur_mwh < 80 and r.renewable_pct > 30, \'GOOD\',\n            p.price_eur_mwh > 150, \'AVOID\',\n            \'NEUTRAL\'\n        )                           as consumption_signal\n    from prices p\n    left join residual r on p.timestamp = r.timestamp\n    left join renewables rn on p.timestamp = rn.timestamp\n)\n\nselect * from joined\norder by joined.timestamp desc',NULL,'853228c8-f726-4279-b4d1-a38f47e670f8','Thread-1 (worker)','table','{"_message": "OK", "query_id": "853228c8-f726-4279-b4d1-a38f47e670f8"}'),('d715940b-b1ef-44cb-b79d-6f386c07ec95.model.elementary.anomaly_threshold_sensitivity','model.elementary.anomaly_threshold_sensitivity','d715940b-b1ef-44cb-b79d-6f386c07ec95','2026-06-30 09:13:50',
    current_timestamp::timestamp
,'anomaly_threshold_sensitivity','OK','success','model',0.02697920799255371,'2026-06-30T09:13:50.197764Z','2026-06-30T09:13:50.214564Z','2026-06-30T09:13:50.189190Z','2026-06-30T09:13:50.197513Z',NULL,False,'\n\nwith metrics_anomaly_score as (\n\n    select * from `energy_marts`.`metrics_anomaly_score`\n\n),\n\nscore_sensitivity as (\n\n    select\n        full_table_name,\n        column_name,\n        metric_name,\n        latest_metric_value,\n        training_avg as metric_avg,\n        training_stddev as metric_stddev,\n        anomaly_score,\n        case when abs(anomaly_score) >= 1.5 then true else false end as "is_anomaly_1_5",\n        case when abs(anomaly_score) >= 2 then true else false end as "is_anomaly_2",\n        case when abs(anomaly_score) >= 2.5 then true else false end as "is_anomaly_2_5",\n        case when abs(anomaly_score) >= 3 then true else false end as "is_anomaly_3",\n        case when abs(anomaly_score) >= 3.5 then true else false end as "is_anomaly_3_5",\n        case when abs(anomaly_score) >= 4 then true else false end as "is_anomaly_4",\n        case when abs(anomaly_score) >= 4.5 then true else false end as "is_anomaly_4_5"\n    from metrics_anomaly_score\n    where abs(anomaly_score) >= 1.5\n\n)\n\nselect * from score_sensitivity',NULL,'99e8a1d8-922c-4736-bcbe-afbd3d7133ee','Thread-1 (worker)','view','{"_message": "OK", "query_id": "99e8a1d8-922c-4736-bcbe-afbd3d7133ee"}'),('d715940b-b1ef-44cb-b79d-6f386c07ec95.model.elementary.alerts_dbt_models','model.elementary.alerts_dbt_models','d715940b-b1ef-44cb-b79d-6f386c07ec95','2026-06-30 09:13:50',
