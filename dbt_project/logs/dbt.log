            -- Core mart for trawa's cost optimization recommendations
with prices as (
    select
        timestamp,
        date,
        hour_of_day,
        value as price_eur_mwh
    from `energy_marts_staging`.`stg_energy_timeseries`
    where category = 'price'
    and filter_id = 4169
),

residual as (
    select * from `energy_marts_intermediate`.`int_residual_load`
),

renewables as (
    select * from `energy_marts_intermediate`.`int_renewable_generation`
),

joined as (
    select
        p.timestamp,
        p.date,
        p.hour_of_day,
        p.price_eur_mwh,
        r.residual_load_mwh,
        r.renewable_pct,
        rn.total_renewable_mwh,
        -- flexibility signal: low price + high renewables = good time to consume
        case
            when p.price_eur_mwh < 50 and r.renewable_pct > 50
                then 'OPTIMAL'
            when p.price_eur_mwh < 80 and r.renewable_pct > 30
                then 'GOOD'
            when p.price_eur_mwh > 150
                then 'AVOID'
            else 'NEUTRAL'
        end as consumption_signal
    from prices p
    left join residual r on p.timestamp = r.timestamp
    left join renewables rn on p.timestamp = rn.timestamp
)

select * from joined
order by timestamp desc
          )
        ...
